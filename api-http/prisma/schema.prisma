generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  creator
  contestee
}

enum SubmissionStatus {
  pending
  accepted
  wrong_answer
  time_limit_exceeded
  runtime_error
}

enum ContestType {
  practice
  competitive
}

enum Difficulty {
  easy
  medium
  hard
}

enum ContestStatus {
  draft
  published
  cancelled
}

enum AttemptStatus {
  in_progress
  submitted
  timed_out
  abandoned
}

model User {
  id         Int     @id @default(autoincrement())
  name       String
  email      String  @unique
  password   String
  isVerified Boolean @default(false)
  imageUrl   String?
  role       Role    @default(contestee)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contests       Contest[]            @relation("ContestCreator")
  mcqQuestions   McqQuestion[]
  dsaProblems    DsaProblem[]
  attempts       ContestAttempt[]
  mcqSubmissions McqSubmission[]
  dsaSubmissions DsaSubmission[]
  leaderboard    ContestLeaderboard[]

  @@index([role])
  @@map("users")
}

model Contest {
  id            Int       @id @default(autoincrement())
  title         String
  description   String
  startTime     DateTime?
  endTime       DateTime?
  maxDurationMs Int?

  type   ContestType   @default(competitive)
  status ContestStatus @default(draft)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId Int
  creator   User @relation("ContestCreator", fields: [creatorId], references: [id])

  questions      ContestQuestion[]
  leaderboard    ContestLeaderboard[]
  attempts       ContestAttempt[]
  mcqSubmissions McqSubmission[]
  dsaSubmissions DsaSubmission[]

  @@index([creatorId])
  @@index([startTime, endTime])
  @@map("contests")
}

model ContestAttempt {
  id Int @id @default(autoincrement())

  userId    Int
  contestId Int

  startedAt   DateTime      @default(now())
  submittedAt DateTime?
  durationMs  Int?
  totalPoints Int           @default(0)
  status      AttemptStatus @default(in_progress)

  user    User    @relation(fields: [userId], references: [id])
  contest Contest @relation(fields: [contestId], references: [id])

  mcqSubmissions McqSubmission[]
  dsaSubmissions DsaSubmission[]

  @@index([userId])
  @@index([contestId])
}

model McqQuestion {
  id                 Int    @id @default(autoincrement())
  questionText       String
  options            Json
  correctOptionIndex Int
  points             Int    @default(1)
  maxDurationMs      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId Int
  createdBy User @relation(fields: [creatorId], references: [id])

  contestLinks ContestQuestion[]
  submissions  McqSubmission[]

  @@map("mcq_questions")
}

model DsaProblem {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  tags        String[] @default([])

  points        Int         @default(100)
  timeLimit     Int         @default(2000)
  memoryLimit   Int         @default(256)
  difficulty    Difficulty?
  maxDurationMs Int?

  boilerplate  Json @default("{}")
  inputFormat String?
  outputFormat String?
  constraints String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId Int
  createdBy User @relation(fields: [creatorId], references: [id])

  testCases    TestCase[]
  submissions  DsaSubmission[]
  contestLinks ContestQuestion[]

  @@map("dsa_problems")
}

model ContestQuestion {
  id        Int @id @default(autoincrement())
  contestId Int
  order     Int

  mcqId Int?
  dsaId Int?

  contest Contest      @relation(fields: [contestId], references: [id])
  mcq     McqQuestion? @relation(fields: [mcqId], references: [id])
  dsa     DsaProblem?  @relation(fields: [dsaId], references: [id])

  @@index([contestId])
}

model TestCase {
  id             Int      @id @default(autoincrement())
  input          String
  expectedOutput String
  isHidden       Boolean  @default(false)
  createdAt      DateTime @default(now())

  problemId Int
  problem   DsaProblem @relation(fields: [problemId], references: [id])

  @@index([problemId])
  @@map("test_cases")
}

model McqSubmission {
  id                  Int      @id @default(autoincrement())
  selectedOptionIndex Int
  isCorrect           Boolean
  pointsEarned        Int      @default(0)
  submittedAt         DateTime @default(now())

  userId     Int
  questionId Int
  contestId  Int
  attemptId  Int

  user     User           @relation(fields: [userId], references: [id])
  question McqQuestion    @relation(fields: [questionId], references: [id])
  contest  Contest        @relation(fields: [contestId], references: [id])
  attempt  ContestAttempt @relation(fields: [attemptId], references: [id])

  @@index([questionId])
  @@index([contestId])
  @@index([attemptId])
  @@map("mcq_submissions")
}

model DsaSubmission {
  id              Int              @id @default(autoincrement())
  code            String
  language        String
  status          SubmissionStatus
  pointsEarned    Int              @default(0)
  testCasesPassed Int              @default(0)
  totalTestCases  Int              @default(0)
  executionTime   Int?
  submittedAt     DateTime         @default(now())

  userId    Int
  problemId Int
  contestId Int
  attemptId Int

  user    User           @relation(fields: [userId], references: [id])
  problem DsaProblem     @relation(fields: [problemId], references: [id])
  contest Contest        @relation(fields: [contestId], references: [id])
  attempt ContestAttempt @relation(fields: [attemptId], references: [id])

  @@index([problemId])
  @@index([contestId])
  @@index([attemptId])
  @@map("dsa_submissions")
}

model ContestLeaderboard {
  id          Int @id @default(autoincrement())
  contestId   Int
  userId      Int
  totalPoints Int
  rank        Int

  contest Contest @relation(fields: [contestId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([contestId, userId])
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  otpHash   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, used])
  @@index([expiresAt])
}
